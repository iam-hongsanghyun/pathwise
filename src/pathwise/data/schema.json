    "fleet_groups": {
      "label": "Fleet groups",
      "columns": {
        "group_id": {"label": "Group", "type": "string", "required": true, "desc": "A fleet-ownership group (alliance / company …) — the transport layer's own tree."},
        "parent_id": {"label": "Parent", "type": "string", "desc": "Parent group id; blank ⇒ top level."},
        "label": {"label": "Name", "type": "string"},
        "level": {"label": "Level", "type": "string", "desc": "Free text: alliance / company / …"}
      }
    },
    "fleet": {
      "label": "Fleet",
      "columns": {
        "fleet_id": {
          "label": "Fleet",
          "type": "string",
          "required": true,
          "desc": "Carrier asset class — a pool of interchangeable units (ships, trucks…)."
        },
        "label": {"label": "Name", "type": "string", "desc": "Display name (the id stays stable)."},
        "group": {"label": "Fleet group", "type": "string", "desc": "Owning fleet group (see fleet_groups); separate from the facility tree."},
        "company": {
          "label": "Company",
          "type": "string",
          "desc": "Owning company (scope); blank ⇒ unscoped."
        },
        "mode": {
          "label": "Mode",
          "type": "string",
          "desc": "Transport mode (sea / road / rail / air)."
        },
        "fuel": {
          "label": "Fuel",
          "type": "string",
          "desc": "Flow the fleet consumes per distance (drives fuel cost + emissions)."
        },
        "cargo": {
          "label": "Cargo",
          "type": "string",
          "desc": "Flow the fleet carries (delivers between stations)."
        },
        "efficiency": {
          "label": "Fuel efficiency",
          "type": "number",
          "desc": "Fuel use per unit cargo per unit distance."
        },
        "capacity": {
          "label": "Capacity / unit",
          "type": "number",
          "desc": "Cargo one unit delivers per year (flat default; overridden by distance + ship size/speed)."
        },
        "count": {
          "label": "Units",
          "type": "number",
          "desc": "Units in service within the lifecycle window."
        },
        "build_year": {"label": "Build year", "type": "integer"},
        "close_year": {"label": "Close year", "type": "integer"},
        "lifespan": {"label": "Lifespan (yr)", "type": "integer"},
        "ship_size": {
          "label": "Cargo / voyage",
          "type": "number",
          "desc": "Cargo one unit carries per voyage; with speed, derives capacity from a route's distance."
        },
        "speed": {"label": "Speed (dist/day)", "type": "number", "desc": "Travel speed in distance units per day."},
        "turnaround_days": {"label": "Turnaround (days)", "type": "number", "desc": "Load + unload time per round trip."},
        "operating_days": {"label": "Operating days/yr", "type": "number", "desc": "In-service days per year (default 350)."},
        "opex": {"label": "O&M / unit / yr", "type": "number", "desc": "Per-carrier annual operating cost (so carrier count carries a cost)."},
        "capex": {"label": "Capex / unit", "type": "number", "desc": "Per-carrier capital cost; >0 lets the optimiser BUILD carriers (charged over the lifespan). Blank ⇒ fixed pool of `count`."},
        "max_build": {"label": "Max build", "type": "number", "desc": "Optional cap on total carriers the optimiser may build over the horizon."}
      }
    },
    "routes": {
      "label": "Routes (physical)",
      "columns": {
        "process": {
          "label": "Route (process)",
          "type": "string",
          "required": true,
          "desc": "Transport process this route's geography belongs to."
        },
        "from_node": {"label": "From", "type": "string", "desc": "Origin node (carries lon/lat)."},
        "to_node": {"label": "To", "type": "string", "desc": "Destination node (carries lon/lat)."},
        "flow": {"label": "Flow", "type": "string", "desc": "Network flow this route physicalises (the link's flow); blank ⇒ a direct transport process."},
        "mode": {"label": "Mode", "type": "string", "desc": "sea (searoute) / road / rail (great-circle × factor)."},
        "distance": {
          "label": "Distance",
          "type": "number",
          "desc": "Route length; blank ⇒ derived from the endpoints' coordinates by mode."
        }
      }
    },
    "corridors": {
      "label": "Corridors (chokepoints)",
