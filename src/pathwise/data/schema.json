        "baseline_technology": {
          "label": "Baseline tech",
          "type": "string",
          "required": true,
          "desc": "The technology it runs at the start of the horizon."
        },
        "capacity": {
          "label": "Capacity (throughput/yr)",
          "type": "number",
          "desc": "Nameplate throughput per year."
        },
        "introduced_year": {
          "label": "Installed",
          "type": "integer"
        },
        "capex": {
          "label": "Build CAPEX",
          "type": "number"
        },
        "fixed_opex": {
          "label": "Fixed O&M (/yr)",
          "type": "number"
