# pathwise configuration — copy to `.env` and adjust.
# Every variable here mirrors a field in src/pathwise/config.py (Settings).
# All keys are prefixed PATHWISE_ and are case-insensitive.

# ── Paths ─────────────────────────────────────────────────────────────────────
PATHWISE_DATA_DIR=data
PATHWISE_OUTPUT_DIR=output
PATHWISE_SCENARIO_DIR=scenarios
PATHWISE_OUTPUT_PATTERN=output/output_{timestamp}.xlsx

# ── Schema / domain ─────────────────────────────────────────────────────────
PATHWISE_SCHEMA_VERSION=1.0
PATHWISE_DEFAULT_DOMAIN=shipping
PATHWISE_DEFAULT_BACKEND=linopy

# ── Economics (CRF / discounting fallbacks) ───────────────────────────────────
PATHWISE_DEFAULT_DISCOUNT_RATE=0.08
PATHWISE_DEFAULT_CARBON_PRICE=0.0
PATHWISE_DEFAULT_MEASURE_LIFETIME_YEARS=15
PATHWISE_DEFAULT_NEWBUILD_LIFETIME_YEARS=25
PATHWISE_BASE_PERIOD=2025
PATHWISE_CURRENCY=USD
PATHWISE_NONCOMPLIANCE_RATE=380.0

# ── Solver ────────────────────────────────────────────────────────────────────
PATHWISE_SOLVER_NAME=highs
PATHWISE_SOLVER_THREADS=4
PATHWISE_SOLVER_TIME_LIMIT_S=600
PATHWISE_SOLVER_MIP_GAP=0.01

# ── Runtime / behaviour ───────────────────────────────────────────────────────
PATHWISE_RANDOM_SEED=42
PATHWISE_IMPUTE_INTENSITY=true
PATHWISE_MAX_JOBS=4
PATHWISE_LOG_BUFFER_SIZE=2000
PATHWISE_LOG_LEVEL=INFO
PATHWISE_VERBOSE=true
