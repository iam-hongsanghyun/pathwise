# pathwise BACKEND configuration — copy to `.env` and adjust.
#
# Server-side only. Model parameters (discount rate, prices, lifetimes, caps,
# feature toggles, …) are user-definable and travel in the scenario per run.
#
# Every variable mirrors a field in src/pathwise/config.py (Settings),
# prefixed PATHWISE_ (case-insensitive).

# ── Serving ─────────────────────────────────────────────────────────────────
PATHWISE_HOST=127.0.0.1
PATHWISE_PORT=8077

# ── Solver resource limits (server-controlled; clamp user requests) ───────────
PATHWISE_SOLVER_NAME=highs
PATHWISE_SOLVER_THREADS=4
PATHWISE_MAX_SOLVER_TIME_LIMIT_S=1800
PATHWISE_DEFAULT_MIP_GAP=0.01
# Stream the HiGHS solver log to the server terminal (set false to silence).
PATHWISE_SOLVER_VERBOSE=true
# HiGHS global scaling (log2 exponents) for large-coefficient models; an exact,
# solution-preserving transform that prevents internal_solver_error.
PATHWISE_HIGHS_USER_BOUND_SCALE=-8
PATHWISE_HIGHS_USER_OBJECTIVE_SCALE=-10

# ── Portfolio backend (server-controlled; clamps user requests) ─────────────────
PATHWISE_MAX_PORTFOLIO_SCENARIOS=50000

# ── Server-side data (the backend owns the working model) ───────────────────────
PATHWISE_DATA_DIR=data
# Example workbooks, the template library, and value-chain specs ship inside the
# backend package (src/pathwise/assets/). Override only to point at custom dirs.
# PATHWISE_EXAMPLES_DIR=
# PATHWISE_LIBRARY_DIR=
# PATHWISE_VALUE_CHAINS_DIR=
PATHWISE_MAX_SHEET_PAGE=1000

# ── Jobs / logging ────────────────────────────────────────────────────────────
PATHWISE_MAX_JOBS=4
PATHWISE_LOG_LEVEL=INFO

# ── Backend identity ──────────────────────────────────────────────────────────
PATHWISE_SCHEMA_VERSION=1.0
